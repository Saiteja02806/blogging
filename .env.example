NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Supabase — Project Settings → API (never commit real keys; GitHub may block secrets).
# Local: copy into .env.local (gitignored). Vercel: Project → Settings → Environment Variables.
SUPABASE_URL=
# Service role: server-only; used by /api/posts/* Route Handlers. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
